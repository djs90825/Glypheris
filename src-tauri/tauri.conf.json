{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "glypheris",
  "version": "0.1.0",
  "identifier": "com.glypheris.compiler",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Glypheris Compiler",
        "width": 1280,
        "height": 800,
        "fullscreen": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["grammars/*", "binaries/models/*"]
  },
  "plugins": {
    "shell": {
      "scope": [
        { "name": "binaries/llama-cpu", "sidecar": true },
        { "name": "binaries/llama-vulkan", "sidecar": true }
      ]
    }
  }
}